<script>
document.addEventListener('DOMContentLoaded', function() {
  const coverImage = document.getElementById('playButton');
  const video = document.getElementById('video_player');
  const playBtn = document.querySelector('.play-icon');

  if (coverImage && video) {
    coverImage.addEventListener('click', () => {
      coverImage.style.display = 'none';
      playBtn.style.display = 'none';
      video.style.display = 'block';
      video.play();
    });

    playBtn.addEventListener('click', () => {
      coverImage.style.display = 'none';
      playBtn.style.display = 'none';
      video.style.display = 'block';
      video.play();
    });
  }

  // Intersection Observer for video pause/play on scroll
  if (video) {
    const videoObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Video is in viewport, play it
          if (video.paused && video.style.display !== 'none') {
            video.play().catch(error => {
              console.log('Video autoplay failed:', error);
            });
          }
        } else {
          // Video is out of viewport, pause it
          if (!video.paused) {
            video.pause();
          }
        }
      });
    }, {
      threshold: 0.5 // Trigger when 50% of video is visible
    });

    videoObserver.observe(video);
  }
});
</script>

<style>
#playButton, #video_player {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  cursor: pointer;
  object-fit: cover;
}

#video_player {
  display: none;
}

.video_width_section {
  max-width: 700px;
  height: 345px;
  margin-top: 50px;
  margin-left: auto;
  margin-right: auto;
  position: relative;
}

.video_width_section video#video_player {
  max-width: 100%;
}

@media(max-width: 550px) {
  .video_width_section {
    height: 191px;
  }
}

.btn-custom {
  background: #193e5a;
  color: white;
  outline: 0;
  border-radius: 10px;
  border: 0;
  padding: 2px 10px;
  margin-top: 10px;
  font-size: 13px;
}

.info-extra img {
  display: block;
  max-width: 100%;
  margin: 0 auto;
}

.bg-custom {
  background: url('	https://cdn.shopify.com/s/files/1/0447/4047/7095/files/GOLD_GRADIENT_Texture_HEADER.png?v=1598553876');
  background-repeat: no-repeat;
  background-size: contain;
}

.play-icon {
  position: absolute;
    bottom: 30px;
    left: 30px;
    max-width: 215px !important;
    z-index: 99;
}

.video_width_section #playButton {
  border-radius: 23px;
}

@media only screen and (max-width:768px) {
  .play-icon {
    max-width: 130px !important;
    height: auto;
    bottom: 20px;
    left: 20px;
  }
}

@media only screen and (max-width:550px) {
  .video_width_section {
    margin-top: 25px;
  }

  .welcome-txt>.container {
    padding: 25px;
  }
}
</style>

{% if section.settings.enable %}
  <div class="block fullboxed {{ section.settings.outer_margin }} welcome-txt" style="background-image: url('{{ section.settings.section_bg_image | img_url: "master" }}'); background-repeat: no-repeat;">
    <div class="container info-extra new-video-btn">

      <h2>{{ section.settings.heading}}</h2>

      <p class="text-center">{{ section.settings.description }}</p>

      {% if section.settings.enable_popup %}
        <a href="javascript:void(0)" class="cstm_popup btn btn-purple">
          <img style="display:inline-block;margin-right:10px;" width="60" src="https://cdn.shopify.com/s/files/1/0508/9994/3601/files/Group_34137.png?v=1744620470" />
          <img class="play-icon" src="https://cdn.shopify.com/s/files/1/0508/9994/3601/files/Group_34136.png?v=1744620670">
        </a>

        <section class="popup">
          <div class="popup__content">
            <div class="close">
              <span></span>
              <span></span>
            </div>
            <video width="600" controls loop playsinline>
              <source src="https://cdn.shopify.com/videos/c/o/v/6b46afcf1cfb4d058dab38d40b9fa83e.mp4" type="video/mp4">
              Your browser does not support HTML5 video.
            </video>
          </div>
        </section>
      {% else %}
        <div class="video_width_section cstm_popup" id="video-{{ section.id }}">
          {% if section.settings.poster != blank %}
            <img src="{{ section.settings.poster | image_url: width: 1000, height: 1000 }}" id="playButton">
            <img class="play-icon" src="https://cdn.shopify.com/s/files/1/0447/4047/7095/files/Group_34136_2x_82d04af4-0273-4555-bd10-a17aed7294cc.png?v=1748224143">
          {% endif %}

          {% if section.settings.video != blank %}
            {{ section.settings.video | video_tag:
              image_size: '1100x',
              autoplay: true,
              class: 'video_player',
              id: 'video_player',
              controls: true,
              muted: false
            }}
          {% else %}
            <video width="700" controls playsinline id="video_player" class="video_player">
              <source src="https://cdn.shopify.com/videos/c/o/v/6b46afcf1cfb4d058dab38d40b9fa83e.mp4" type="video/mp4">
              Your browser does not support HTML5 video.
            </video>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>

  <div class="block {{ section.settings.block_width }} offset-top-negative-100">
    <div class="container">
      <div class="row row-flex-sm no-gutter promo-box-row">
        {% assign link_targets = "link_1,link_2,link_3" | split: "," %}
        {% assign link_target_values = "link_target_1,link_target_2,link_target_3" | split: "," %}
        {% assign icons = "icon1,icon2,icon3" | split: "," %}
        {% assign captions_1 = "box_1_caption_1,box_2_caption_1,box_3_caption_1" | split: "," %}
        {% assign captions_2 = "box_1_caption_2,box_2_caption_2,box_3_caption_2" | split: "," %}

        {% for i in (0..2) %}
          <div class="col-sm-4">
            {% assign link_key = link_targets[i] %}
            {% assign target_key = link_target_values[i] %}
            <a {% if section.settings[link_key] %}href="{{ section.settings[link_key] }}" target="{{ section.settings[target_key] }}"{% endif %} class="promo-box text-center">
              <span class="count_cstm">{{ i | plus: 1 }}</span>
              <div class="promo-box-icon">
                {% assign icon_key = icons[i] %}
                {% if section.settings[icon_key] != blank %}
                  <img src="{{ section.settings[icon_key] | img_url: 'grande' }}">
                {% else %}
                  <img src="https://dummyimage.com/250x100">
                {% endif %}
              </div>
              <h3 class="promo-box-title promo-box-title-ct">{{ section.settings[captions_1[i]] }}</h3>
              <div class="promo-box-text">{{ section.settings[captions_2[i]] }}</div>
            </a>
          </div>
        {% endfor %}
      </div>

                                <!-- <button class="btn-custom bottom-btn" onclick="location.href= '/pages/how-it-works-new';">Learn More</button> -->
      <a href="/collections/everyday-picks" class="btn-velvey bottom-btn homepage-btn"><img src="https://cdn.shopify.com/s/files/1/0447/4047/7095/files/icon_vel.png?v=1628848389" /> Send a Velvey</a>
    </div>
  </div>
{% endif %}

<style>
.bottom-btn {
      position: absolute;
    bottom: -103px;
    left: 50%;
    transform: translate(-50%);
    margin: 0;
    width: 100%;
    max-width: 362px;
    min-height: 53px;
    border-radius: 10px;
    font-size: 23px;
    font-weight: 700;
    font-family: Montserrat;
    letter-spacing: 0;
    line-height: 28px;
    color: #fff;
    background: #eea822 !important;
}
</style>

