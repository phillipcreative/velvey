        </p>
      </div>
    </div>
    <div class="row">
      <div class="col-12 pd-0 text-center">

        <div
          class="value-button"
          id="decreasegift"
          onclick="decreaseValue()"
          value="Decrease Value">-</div>
        <input
          type="text"
          class="gift-input"
          id="numbergift"
          value="$25.00"
          disabled />
        <div
          class="value-button"
          id="increasegift"
          onclick="increaseValue()"
          value="Increase Value">+</div>


        <ul class="gift-options" id="gift-options-ul">
          {% for variant in all_products['gift-card-voucher-new'].variants %}
            {% if variant.available %}
              <li
                data-variant="{{ variant.id }}"
                data-price="{{variant.price |  money}}"
                data-price-format="{{variant.price | money }}"
                onclick="changeprice_li(this)">
                {{ variant.price | money }}
              </li>
            {% endif %}
          {% endfor %}
        </ul>



      </div>
      <div class="d-sm-flex justify-content-center text-center">
        <a href="/cart" class="gift-btn-gray w-100 mr-4 w-sm-auto dev-rounded">
          Skip
        </a>

        <a
          href="javascript:void(0)"
          class="gift-btn-gold toaddgift w-100 w-sm-auto dev-rounded"
          data-id="42686461214896"
          id="add_bag">
          Add to Cart
        </a>
      </div>


    </div>


  </div>
</script>

