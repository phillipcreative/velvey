{% unless customer %}
  <!-- Modal Login -->
  <div class="modal modal-form fade zoom" id="modalLogin">
    <div class="modal-dialog">
      <div class="modal-header">
        <button
          type="button"
          class="close"
          data-dismiss="modal"
          aria-label="Close"
        >
          &#10006;
        </button>
      </div>
      <div class="modal-content">
        <div class="modal-body">
          <div class="form-wrap-login active">
            <div class="modal-title">{{ 'general.theme.login' | t }}</div>
            <p class="text-center">{{ 'customer.login.if_have_title' | t }}</p>
            <!-- form -->
            {% form 'customer_login' %}
              <div class="label">
                {{ 'customer.login.email' | t -}}
                <span class="required">*</span>
              </div>
              <input
                type="email"
                class="form-control"
                name="customer[email]"
                placeholder="{{ 'customer.login.email' | t }}*"
              >
              <div class="label">
                {{ 'customer.login.password' | t -}}
                <span class="required">*</span>
              </div>
              <input
                type="password"
                class="form-control"
                name="customer[password]"
                placeholder="{{ 'customer.login.password' | t }}*"
              >
              <p>
                <a href="#" class="js-change-form">Forgot Password</a>
              </p>
              <button type="submit" class="btn btn-lg btn-full">{{ 'customer.login.sign_in' | t }}</button>
            {% endform %}
            <!-- /form -->
            <p class="text-center">{{ 'customer.login.or' | t }}</p>
            <a class="btn btn-lg btn-full btn-alt" href="/account/register">
              {{- 'layout.customer.create_account' | t -}}
            </a>
          </div>
        </div>
        <div class="form-wrap-password">
          <div class="modal-title">{{ 'customer.recover_password.title' | t }}</div>
          <p>{{ 'customer.recover_password.subtext' | t }}</p>
          <!-- form -->
          {% form 'recover_customer_password' %}
            <input
              class="form-control"
              type="email"
              value=""
              name="email"
              id="RecoverEmail"
              placeholder="{{ 'customer.recover_password.email' | t }}"
            >
            <p>
              <a href="#" class="js-change-form">{{ 'customer.recover_password.cancel' | t }}</a>
            </p>
            <button type="submit" class="btn btn-lg btn-full">{{ 'customer.recover_password.submit' | t }}</button>
          {% endform %}
          <!-- /form -->
        </div>
      </div>
    </div>
  </div>
  <!-- /Modal Login -->
{% endunless %}

