      /* font-size */
      --heading: 24px;
      --sub-heading: 12px;
      --search-icon: 16px;
      --voucher-points: 10px;
      --voucher-name: 12px;
    }

  }
  :root {
    /* font-family */
    --primary-family: Work Sans, sans-serif;
    --feature-card-font-family: 'Kumbh Sans', 'Helvetica', 'Arial', sans-serif;

    /* font-size */
    --heading: 32px;
    --sub-heading: 18px;
    --search-icon: 20px;
    --voucher-points: 12px;
    --voucher-name: 12px;
  }



  .gift-card .header-sec {
    font-family: var(--primary-family);
  }

  .gift-card .heading {
    text-align: center;
    color: #ffc000;
    font-size: var(--heading);
    text-transform: uppercase;
    margin-bottom: 0;
  }

  .gift-card .sub-heading {
    margin-top: 0;
    text-align: center;
    font-size: var(--sub-heading);
  }

  .gift-card .box-fluid {
    /* width: 100%; */
    margin: auto;
    padding: 1.5rem;
    font-family: var(--feature-card-font-family);
  }

  .gift-card .box-fluid .box-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    /* gap: 0.5rem; */
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
    /* margin: auto; */
  }

  .gift-card .box-fluid .box-header .box-heading {
    font-weight: 200 !important;
    margin: 0;
    color: #666;
  }

  .gift-card .box-fluid .box-header .search-box {
    display: flex;
    min-width: 350px;
    background-color: rgba(0, 0, 0, 0.05);
    border-radius: 3px;
  }

  .gift-card .box-fluid .box-header .search-box .btn-search {
    padding: 0.375rem;
    border: 0;
    color: #666;
    border-radius: 3px;
    background-color: transparent;
    font-size: var(--search-icon);
  }

  .gift-card .box-fluid .box-header .search-box .search-input {
    height: 45px;
    font-size: 18px;
    padding-left: 15px;
    /* padding-right: 30px; */
    width: 100%;
    border-radius: 3px !important;
    background-color: transparent;
    border: none !important;
    box-shadow: none;
    transition: 0.25s ease;
    transition-property: box-shadow, background-color !important;
    margin: 0;
  }

  .gift-card .box-fluid .box-header .search-box .search-input:focus {
    outline: 0 !important;
  }

  .gift-card .box-fluid .box-header .search-box:has(.search-input:focus) {
    background-color: #fff;
    box-shadow: 0 3px 5px -1px rgba(0, 0, 0, 0.2), 0 6px 10px 0 rgba(0, 0, 0, 0.14), 0 1px 18px 0 rgba(0, 0, 0, 0.12);
  }

  .gift-card .box-fluid .box-header .search-box .btn-search:hover {
    background-color: #f5f9fc;
  }

  .gift-card .box-fluid .box-body {
    /* width: 100%; */
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .gift-card .box-fluid .box-body .voucher-card {
    width: 200px;
    {% comment %}
      max-width: 350px;
    {% endcomment %}
    height: 100%;
    box-shadow: 0 3px 1px -2px rgba(0, 0, 0, 0.2), 0 2px 2px 0 rgba(0, 0, 0, 0.14), 0 1px 5px 0 rgba(0, 0, 0, 0.12);
  }

  .gift-card .box-fluid .box-body .voucher-card .voucher-img {
    width: 100%;
    height: 120px;
  }

  .gift-card .box-fluid .box-body .voucher-card .voucher-card-footer {
    padding: 0.5rem 1rem;
    /* border-top: 1px solid #cfcfcf; */
  }

  .gift-card .box-fluid .box-body .voucher-card .voucher-card-footer .voucher-name {
    margin: 0;
    font-size: var(--voucher-name);
    overflow: hidden;
    width: 100%;
    text-wrap: nowrap;
    text-overflow: ellipsis;
    line-height: 1;
  }

  .gift-card .box-fluid .box-body .voucher-card .voucher-card-footer .voucher-points {
    margin: 0;
    /* text-align: end; */
    color: #357a38;
    font-size: var(--voucher-points);
  }

  .gift-card .box-fluid .box-footer {
    padding: 1.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
  }

  .gift-card .box-fluid .box-footer .btn-next,
  .gift-card .box-fluid .box-footer .btn-prev {
    padding: 1rem;
    background-color: #ffc000;
    color: white;
    border: 0;
    border-radius: 4px;
  }

  @media screen and (max-width:690px) {

    .gift-card .box-fluid {
      padding: 0.25rem;
    }

    .gift-card .box-fluid .box-body .voucher-card {
      width: 100px;
    }
    .gift-card .box-fluid .box-body .voucher-card .voucher-img {
      height: 100px;
    }
    .gift-card .box-fluid .box-header .search-box {
      min-width: 5px;
    }
    .gift-card .box-fluid .box-header .search-box .search-input {
      height: 35px;
    }
  }
</style>
<script id="giftcard-template" type="text/x-handlebars-template">
  <div class="container-fluid">
    <div class="row" style="margin-bottom: 2rem;">
      <div class="col-md-12 pd-0">
        <div class="gifcard-content">
          <div class="giftcard-heading text-uppercase">Select your gift card voucher amount</div>
        </div>
      </div>
    </div>
    <div class="row">
      <div class="col-md-4 pd-0">
        <img
          width="190"
