    function increaseValue() {
      var value = document.getElementById('numbergift').value;
      let giftPrices = [];
      $("#gift-options-ul").children().each((i, e) => giftPrices.push({
        'price': $(e).data('price') / 100,
        id: $(e).data('variant'),
        priceFormat: $(e).data('price-format')
      }));
      var position = giftPrices.findIndex(s => s.priceFormat == value);

      if (position > -1) {
        position++
        if (cprices[position] !== undefined) {
          document.getElementById('numbergift').value = giftPrices[position].priceFormat;
          document.getElementById('add_bag').setAttribute("data-id", giftPrices[position].id);
        }
      }
    }

