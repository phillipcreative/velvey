{% assign product_image_size = section.settings.product_image_size %}
{% assign product_options = settings.product_options %}
{% if product.metafields.c_f.product_image_size != blank -%}
  {%- assign product_image_size = product.metafields.c_f.product_image_size -%}
{%- endif %}
{% if product.metafields.c_f.product_options != blank -%}
  {%- assign product_options = product.metafields.c_f.product_options -%}
{%- endif %}
{% assign sold_out = true %}
{% if product.available %}
  {% assign sold_out = false %}
{% endif %}
{% assign on_sale = false %}
{% if product.compare_at_price > product.price %}
  {% assign on_sale = true %}
{% endif %}
<a href="#" class="selected-currency hidden">{{ shop.currency }}</a>
<div itemscope itemtype="http://schema.org/Product">
  <meta itemprop="url" content="{{ shop.url }}{{ product.url }}">
  <meta itemprop="name" content="{{ product.title }}">
  <meta itemprop="image" content="{{ product.featured_image.src | img_url: 'grande' }}">
  {% if design == 'default' -%}
    {%- include 'product-page-design-default' -%}
  {%- else %}
    {% include 'product-page-design-creative' %}
  {% endif %}
  {% comment %}  {% unless product.metafields.c_f.notabs != blank %}{% include 'product-tabs' %}{% endunless %}{% endcomment %}
</div>

{% assign product_card_front = product.metafields.custom.product_card_front %}
{% assign product_card_back = product.metafields.custom.product_card_back %}
{% assign envelope_front = product.metafields.custom.product_envelope_front %}
{% assign envelope_back = product.metafields.custom.product_envelope_back %}

<div class="ebeded_description_pics">
  <div class="container">
    <div class="row">
      <div class="col-md-3">
        <img src="{{ product_card_front | img_url: '800x' }}" style="width: 100%; height: auto;" width="300" height="400" alt="Product Card Front">
        <a
          href="{{ product_card_front | img_url: '800x' }}"
          class="zoom-link  disable-gallery"
          ><i class="icon icon-zoomin"></i>Zoom</a
        >
      </div>
      <div class="col-md-3">
        <img src="{{ product_card_back | img_url: '800x' }}" style="width: 100%; height: auto;" width="300" height="400" alt="Product Card Back">
        <a
          href="{{ product_card_back | img_url: '800x' }}"
          class="zoom-link  disable-gallery"
          ><i class="icon icon-zoomin"></i>Zoom</a
        >
      </div>
      <div class="col-md-3">
        <img src="{{ envelope_front | img_url: '800x' }}" style="width: 100%; height: auto;" width="300" height="400" alt="Envelope Front">
        <a
          href="{{ envelope_front | img_url: '800x' }}"
          class="zoom-link  disable-gallery"
          ><i class="icon icon-zoomin"></i>Zoom</a
        >
      </div>
      <div class="col-md-3">
        <img src="{{ envelope_back | img_url: '800x' }}" style="width: 100%; height: auto;" width="300" height="400" alt="Envelope Back">
        <a
          href="{{ envelope_back | img_url: '800x' }}"
          class="zoom-link  disable-gallery"
          ><i class="icon icon-zoomin"></i>Zoom</a
        >
      </div>
    </div>
    <div id="gtx-trans" style="position: absolute; left: -26px; top: -20px;">
      <div class="gtx-trans-icon"></div>
    </div>
  </div>
</div>

{% if section.settings.product_related_enable %}
  {% include 'related-products' %}
{% endif %}
