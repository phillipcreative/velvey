 .banner-messages{
     max-width: 100%;
     margin: 0 auto;
     display: block;
}
 .bg-messages{
     min-height: 400px;
     background: url(https://cdn.shopify.com/s/files/1/0447/4047/7095/files/GOLD_GRADIENT.jpg?v=1598557572);
     background-repeat: no-repeat;
     background-size: 100% 500px;
}
.audio-input{
margin: 0 10px;
}

.btn-form.no-border{
color: #e4aa44 !important;
  background: transparent;
    border: 0;
    padding: 0;
    margin: 0;
}
.btn-form{
background: #e4aa44;
    border: 1px solid #e4aa44;
    color: #fff !important;
    padding: 5px 20px;
    border-radius: 0;
    font-size: 1.2em;
    font-weight: 500;
    display: inline-block;
    text-transform: uppercase;
    text-decoration: none !important;
}
.contact-info{
    padding: 20px 30px;
    font-weight: 500;
  padding-top:80px;
}
.contact-info a{
text-decoration: underline !important;
  color: #e4aa44 !important;
}

.form-content h2{
      font-weight: bold;
    font-size: 2.3em;
margin: 30px 0;
  text-transform:uppercase;
}

.form-content textarea{
width:100%;
  resize: none;
      border: 2px solid black;
}
.row-types img{
    max-width: 100%;
    display: block;
    margin: 0 auto;
    width: 120px;
   cursor:pointer;
}

.row-types h1{
  font-weight: bold;
    margin-top: 40px;
    font-size: 2.3em;
}
.row-types span{
    font-weight: bold;
    padding: 10px 0;
    display: block;
    text-align: center;
    font-size: 1.1em;
}
 .container-messages{
    display: block;
    width: 100%;
    margin: 0 auto;
    text-align: center;
    padding-top: 50px;
}
.desc-messages{
margin-bottom:50px;
}
.btn-inner{
max-width:600px;
      margin: 0 auto;
}
 .info-messages{
     background: #e4aa44;
     border-radius: 50px;
     display: block;
     width: 100%;
     max-width: 500px;
     margin: 0 auto;
     color: white;
     padding: 20px 10px;
}
 .info-messages p {
     font-size:1.1em;
     margin:0;
}
 .btn-messages{
     display:block;
     margin-bottom:50px;
}
 .btn-m{
     background: #fff;
     border: 1px solid #e4aa44;
     color: #e4aa44 !important;
     padding: 8px 30px;
     border-radius: 25px;
     font-size: 1.5em;
     font-weight: 500;
     display: inline-block;
     text-transform: uppercase;
     text-decoration: none !important;
}
.audio-area{
    border: 2px solid #000;
    padding: 15px 0;
  margin: 20px auto;
  max-width:600px;
}
.audio-area p{
margin:0;
  font-weight:500;
}
.input-messages{
max-width:325px;
  margin:40px auto;
}
.input-messages .input-1{
  background: transparent;
    border: 2px solid black;
    font-size: 2em;
    height: 50px;
    text-align: center;
}

.input-1::placeholder,.input-2::placeholder{ 
  color: #e4aa44;
  opacity:0.6;
  font-weight:bold,
}

.form-content{
text-align:center;
  max-width:800px;
  margin:0 auto;
}
.message-type{
text-align:center;
  max-width:600px;
  margin:0 auto;
}

.got-form{
      display: block;
    max-width: 800px;
    margin: 0 auto;
  padding-top: 30px;
  text-align:left;
}
.input-2 {
    height: 45px;
    margin: 0;
}
.info p{
font-weight:500;
}
.got-form label{
  font-size:18px;
  font-weight: 500;
color:#e4aa44 !important;
  position: relative;
    top: 9px;
}
.row-types{
  text-align:center;
}
.input-1:-ms-input-placeholder, .input-2:-ms-input-placeholder{ 
  color: #e4aa44;
}

.input-1::-ms-input-placeholder, .input-2::-ms-input-placeholder  {
  color: #e4aa44;
}

 .btn-m.active{
     background: #e4aa44;
     color: #fff !important;
}
 @media screen and (max-width: 991px) {
   
   
}
 @media screen and (max-width: 768px) {
   .got-form label{
   top:0;
     font-size:16px;
   }
    .info-messages{
     border-radius: 35px;
     padding: 15px 10px;
}
   .info-messages p{
   font-size:0.9em;
   }
   .btn-m{
       font-size: 0.9em;
     padding: 5px 10px;
   }
   .form-content h2{
    font-size: 1.5em;
   }
   .row-types h1{
     margin-top:20px;
       font-size: 1.5em;
   }
   .row-types span{
      font-size:0.9em;
     line-height:1.2;
   }
   
}
