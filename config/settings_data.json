      "faq": {
        "type": "faq",
        "blocks": {
          "1504373463945": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "How long does shipping take?",
              "answer": "While we're not Amazon, we're pretty speedy. Depending on where you send your Velvey, shipping takes 2-4 days."
            }
          },
          "1504373907224": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "Can I ship internationally?",
              "answer": "We wish! But right now, to keep your costs low and our shipping time speedy, Velvey only ships within the continental US."
            }
          },
          "1504373996834": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "What do I do if my order is damaged in transit or never arrives?",
              "answer": "We hope that NEVER happens! But if the impossible does occur, please contact us directly at <a href=\"service@velvey.com\">service@velvey.com</a>. Let us know what happened, and we'll ship a fresh new order for you right away—hassle-free."
            }
          },
          "1504374014438": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "Is your candy safe for those with nut allergies?",
              "answer": "At Velvey, we're committed to our customers' happiness and the health and safety of those you care about. To the best of our ability, we store our candy in a nut-free environment and list any treats containing nuts or manufactured in a shared environment."
            }
          },
          "1504374021920": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "What do I do if the code on my card or packing slip doesn't work?",
              "answer": "Email us at <a href=\"service@velvey.com\">service@velvey.com</a> with the code that isn’t working, and a customer service agent will reply shortly."
            }
          },
          "1504374041263": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "How do I get a THANK YOU message?",
              "answer": "Getting a \"thank you\" isn't actually guaranteed. That's up to your recipient! (But we hope they will. You deserve it.)"
            }
          },
          "item_pNGfNH": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "My Velvey included a digital gift card. How do I redeem it?",
              "answer": "If your Velvey included a digital gift card, the screen where you read, listened to, or watched the personal message from the sender of your Velvey, would have included a notification stating that a digital gift card was included. If it did, you simply enter your email address and we’d email you the redemption instructions. If you didn’t see a notification, then a digital gift card was most likely not included. \n\nIf you need any additional assistance, please don’t hesitate to contact us at service@velvey.com."
            }
          },
          "item_ppiryd": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "I want to change the shipping address, but my order already shipped!",
              "answer": "Once an order has shipped, we are limited in what we can do. But if it hasn’t, we’d be happy to accommodate your request and change the shipping address. Just email us at service@velvey.com."
            }
          },
          "item_qXteJg": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "Can I pay for faster shipping?",
              "answer": "Yes! We offer multiple expedited options at checkout."
            }
          },
          "item_UJP7XM": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "Can I schedule my order to ship on a specific date?",
              "answer": "We can’t currently schedule your order, but hopefully, that’s an option in the future."
            }
          },
          "item_E4XA6b": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "Help! I changed my mind. Can I cancel my order?",
              "answer": "Due to our quick shipping, the time to cancel an order is very short. We might not always be able to cancel, but we’ll try our best. Just email us at service@velvey.com."
            }
          },
          "item_ehNhqh": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "My Velvey didn’t reach its destination. What do I do?",
              "answer": "We’re sorry to hear that your package didn’t reach its destination. When this happens, the package is routed back to our fulfillment center in Utah, which can take several weeks. If returned, our support team will contact you to discuss the details. \nAs a rule, we will refund the box upon receipt minus a 35% restocking fee for the labor, discard perishables and custom items, and then reship to the correct address for a $3-$8 fee, depending on the weight and location."
            }
          },
          "item_MCFYQK": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "When is my order considered lost?",
              "answer": "Our policy is to wait 14 days from the last tracking update before considering a package lost in transit. This allows our shipping partners to work through any possible shipping delays due to COVID-19 precautions, inclement weather, increases in shipping volume, etc. \n\nHowever, once we determine the order is lost, we will happily reship it for you at no additional cost! We appreciate your patience and understanding as our shipping partners work hard to deliver your Velvey! \n\nIf you have any questions regarding your order, feel free to email our Customer support team at service@velvey.com."
            }
          },
          "item_n83PQn": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "My lost order included a gift card. What do I do now?",
              "answer": "Email us at service@velvey.com with your order number, and a customer service agent will look into it and get back to you shortly."
            }
          },
          "item_fLqwxE": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "I’m shopping for my company/school. How do I make a bulk order with you?",
              "answer": "Velvey is a fun, affordable solution for businesses! We have been able to accommodate bulk orders for employee recognition, client thank yous, and many other occasions. Please contact service@velvey.com with more information about your gifting needs and we’ll route your request to the appropriate person within our organization that can assist you."
            }
          },
          "item_4WxbqW": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "I’m interested in collaborating with Velvey. Who do I contact?",
              "answer": "We would love to consider working with you. Please email service@velvey.com and we’ll route your email to the appropriate person within our organization that can respond to your inquiry."
            }
          },
          "item_DneUcP": {
            "type": "item",
            "settings": {
              "enable": true,
              "title": "Got a question we didn’t answer?",
              "answer": "Email us at service@velvey.com, and a customer service agent will get back to you shortly."
            }
          }
        },
